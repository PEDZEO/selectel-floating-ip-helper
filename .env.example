# X-Token Selectel. Возьмите его в панели Selectel и не публикуйте в Git.
SELECTEL_X_TOKEN=

# ID проекта Selectel, куда будут создаваться floating IP.
SELECTEL_PROJECT_ID=

# Регион floating IP. Например: ru-2 или ru-3.
SELECTEL_REGION=ru-2

# Папка со списками разрешенных IP/CIDR.
# Для Linux и Windows можно оставить относительный путь: ip/strict
SELECTEL_IP_LIST_DIR=ip/strict

# Максимальное число попыток поиска. 0 означает без ограничения.
SELECTEL_MAX_ATTEMPTS=0

# Задержка между попытками поиска в секундах.
SELECTEL_DELAY_SECONDS=20

# Случайный разброс задержки, чтобы запросы не шли строго по таймеру.
SELECTEL_DELAY_JITTER_SECONDS=8

# Количество повторов API-запросов при временных ошибках.
SELECTEL_API_RETRIES=8

# Начальная задержка backoff при ошибках API.
SELECTEL_BACKOFF_BASE_SECONDS=10

# Максимальная задержка backoff при ошибках API.
SELECTEL_BACKOFF_CAP_SECONDS=120

# Таймаут HTTP-запросов к API Selectel.
SELECTEL_HTTP_TIMEOUT_SECONDS=60

# Минимальная пауза после создания floating IP перед проверкой адреса.
SELECTEL_POST_CREATE_MIN_DELAY_SECONDS=12

# Максимальная пауза после создания floating IP перед проверкой адреса.
SELECTEL_POST_CREATE_MAX_DELAY_SECONDS=25

# Режим вывода в консоль. compact подходит для обычного запуска.
SELECTEL_OUTPUT_MODE=compact

# Токен Telegram-бота для подтверждения найденного IP.
TELEGRAM_BOT_TOKEN=

# Chat ID, из которого разрешено подтверждение через Telegram.
TELEGRAM_CHAT_ID=

# Включить подтверждение найденного подходящего IP через Telegram: 1 - да, 0 - нет.
SELECTEL_TELEGRAM_CONFIRM_MATCH=0

# Сколько секунд ждать ответ в Telegram.
SELECTEL_TELEGRAM_CONFIRM_TIMEOUT_SECONDS=600

# Действие по таймауту: keep_continue, keep_stop или delete_continue.
SELECTEL_TELEGRAM_CONFIRM_DEFAULT_ACTION=keep_stop
